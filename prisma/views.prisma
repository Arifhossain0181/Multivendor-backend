model ProductView {
  id        String   @id @default(cuid())
  productId String

  // dedupe key based on identity + time window/session logic in app
  dedupeKey String

  userId    String?
  viewedAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([productId, dedupeKey])
  @@index([productId, dedupeKey])
  @@map("product_views")
}